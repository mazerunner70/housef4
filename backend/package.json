{
  "name": "@housef4/backend",
  "version": "1.0.0",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && pnpm run build:lambda",
    "build:lambda": "node scripts/build-lambda.mjs",
    "dev": "tsc -w",
    "start:local": "node dist/adapters/localServer.js",
    "test": "pnpm run build && node --test test/dispatch.test.cjs test/merchantNormalize.test.cjs",
    "test:integration-cognito": "pnpm run build && node --test test/integration-cognito-smoke.cjs"
  },
  "dependencies": {
    "@housef4/db": "workspace:*",
    "busboy": "^1.6.0",
    "csv-parse": "^6.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.136",
    "@types/busboy": "^1.5.4",
    "@types/node": "^20.11.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.4.0"
  }
}
